# ── Зависимости ───────────────────────────────────────────────
node_modules/

# ── Сборка ────────────────────────────────────────────────────
dist/
dist-ssr/
*.tsbuildinfo

# ── Окружение и секреты — НЕ коммитим ─────────────────────────
# Паттерн без слеша ловит файл в любой подпапке:
# work/.env, mrdk-back/.env, mrdk-front/.env — все игнорируются.
.env
.env.local
.env.*.local
*.local
secrets/
# NB: .env.example (mrdk-back) и .env.production (mrdk-front) — НЕ секреты,
# они нужны и коммитятся; правила выше их не задевают.

# ── Тесты / покрытие ──────────────────────────────────────────
coverage/

# ── Логи ──────────────────────────────────────────────────────
*.log
logs/

# ── ОС и редакторы ────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# ── Контент-загрузки (правила специфичны для папки) ───────────
# см. mrdk-back/.gitignore — там скелет uploads через .gitkeep.

# Скопируйте в .env и заполните значениями. .env в репозиторий НЕ коммитится.

NODE_ENV=development
PORT=3001

# Postgres
DATABASE_URL=postgresql://user:password@localhost:5432/mrdk
POSTGRES_PASSWORD=

# Длинная случайная строка, напр. `openssl rand -base64 64`
JWT_SECRET=

# Список разрешённых origin фронтенда через запятую (без хвостовой запятой)
CLIENT_ORIGIN=http://localhost:5173
GOSUSLUGI_ORIGIN=https://gosuslugi.ru

# Учётка администратора. Пароль нужен ТОЛЬКО при первом старте на пустой БД
# (для создания админа); дальше сервер стартует и без него.
ADMIN_LOGIN=
# Путь к файлу с паролем (имеет приоритет над ADMIN_PASSWORD):
#   dev:  ../secrets/admin_password (общий с docker-compose секрет)
#   prod: /run/secrets/admin_password (docker secret, задаётся в compose)
ADMIN_PASSWORD_FILE=../secrets/admin_password
# Либо паролем напрямую (не рекомендуется):
# ADMIN_PASSWORD=

# SMTP для формы обратной связи
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=user@example.com
SMTP_PASS=
ADMIN_EMAIL=admin@example.com
